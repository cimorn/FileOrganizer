{
  "name": "file-organizer",
  "version": "26.7.2",
  "releaseVersion": "26.07.02",
  "description": "文件整理：本地文件预览、批量改名、移动、表格改名和时间修改工具",
  "type": "module",
  "main": "electron/main.js",
  "author": "File Organizer contributors",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vite build --outDir dist/renderer",
    "test": "vitest run",
    "desktop": ".\\dist\\文件整理-v26.07.02.exe",
    "build:desktop": "pnpm run build && node scripts/sync-desktop-dist.mjs",
    "release:desktop": "pnpm run build && pnpm exec electron-builder --win dir --x64 --publish never && node scripts/sync-desktop-dist.mjs"
  },
  "build": {
    "appId": "local.file-organizer",
    "productName": "文件整理",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/app-icon.ico"
    },
    "files": [
      "assets/**/*",
      "electron/**/*",
      "dist/renderer/**/*",
      "src/shared/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "exifr": "^7.1.3",
    "lucide-react": "^0.468.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  }
}
